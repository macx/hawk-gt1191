{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "pnpm run dev",
      "type": "shell",
      "command": "pnpm dev",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": "Local\\s+https?://\\S+"
        }
      }
    }
  ]
}
