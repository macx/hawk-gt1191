{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "🚀 Development",
      "type": "editor-browser",
      "request": "launch",
      "url": "http://localhost:4321",
      "webRoot": "${workspaceFolder}",
      "preLaunchTask": "pnpm run dev"
    },
    {
      "command": "pnpm release",
      "cwd": "${workspaceFolder}",
      "name": "🚢 Release & Deploy",
      "request": "launch",
      "type": "node-terminal"
    }
  ]
}
