---
import { getCollection } from 'astro:content'
import BaseLayout from '@layouts/BaseLayout.astro'
import ArticleCard from '@components/ArticleCard.astro'
import Switch from '@components/Switch.astro'

export async function getStaticPaths() {
  const learningPaths = await getCollection('learningPaths')
  learningPaths.sort((a: any, b: any) => a.data.order - b.data.order)

  return learningPaths.map(({ data }) => ({
    params: { slug: data.slug },
    props: { ...data, learningPaths }
  }))
}

const { title, description, related, learningPaths, order } = Astro.props
const layout = 'medium'
const tutorials = await getCollection('tutorials')

const collection = (related ?? []).map((id: string) => {
  const tutorial = tutorials.find((tutorial) => tutorial.id === id)
  return tutorial ? tutorial : null
})
---

<BaseLayout title={title} description={description} layout={layout}>
  <div class='learnpath-header'>
    <div class='title-header'>
      <h1>
        <span>Tutorials:</span>
        Lernpfade
      </h1>

      <p class='t-small'>
        Lernpfade sind kuratierte Tutorials in logischer Reihenfolge zum
        schrittweisen Erlernen eines&nbsp;Themas.
      </p>
    </div>

    <div>
      <Switch
        entries={learningPaths.map(({ data }: { data: any }) => ({
          title: data.title || '',
          slug: data.slug || ''
        }))}
      />

      <p>
        Im Lernpfad <strong>{title}</strong>
        {description}
      </p>
    </div>
  </div>

  {
    collection && collection.length > 0 && (
      <ul class='timeline' data-articles={collection.length} data-order={order}>
        {collection.map((tutorial: any) => (
          <li>
            <ArticleCard article={tutorial} />
          </li>
        ))}
      </ul>
    )
  }

  <p>
    Weiterführende Tutorials findest du&nbsp;<a href='/tutorials'>hier</a>.
  </p>
</BaseLayout>

<style>
  .timeline {
    --path-accent: var(--clr-primary);

    &[data-order='1'] {
      --path-accent: var(--clr-learning-path-1-accent);
    }

    &[data-order='2'] {
      --path-accent: var(--clr-learning-path-2-accent);
    }

    &[data-order='3'] {
      --path-accent: var(--clr-learning-path-3-accent);
    }

    &[data-order='4'] {
      --path-accent: var(--clr-learning-path-4-accent);
    }

    li :global(.article-card.media-item-article) {
      transition:
        background-color var(--transition),
        border-color var(--transition),
        box-shadow var(--transition);
    }

    li :global(.article-card.is-link:hover),
    li :global(.article-card.is-link:focus-within) {
      background-color: color-mix(
        in oklab,
        var(--path-accent) 8%,
        var(--clr-bg-card)
      );
      border-color: color-mix(
        in oklab,
        var(--path-accent) 35%,
        var(--clr-line)
      );
    }
  }

  .learnpath-header {
    margin-block-end: var(--sp-l);

    .title-header {
      display: flex;
      flex-direction: column;
      gap: var(--sp-s);
      margin-block-end: var(--sp-m);

      h1 {
        margin-block: 0;
      }
    }

    @media screen and (width >= 37.5em) {
      .title-header {
        max-inline-size: unset;
        flex-direction: row;
        justify-content: space-between;
        align-items: flex-end;
        gap: var(--sp-m);

        p {
          flex: 1 1 auto;
          max-inline-size: 50ch;
          text-align: end;
        }
      }
    }
  }
</style>
