---
import type { CollectionEntry } from 'astro:content'
import BaseLayout from './BaseLayout.astro'
import { formatTitle } from '@plugins/remark-widont.mjs'
import Lead from '@components/Lead.astro'
import ArticleMeta from '@components/ArticleMeta.astro'
import Tags from '@components/Tags.astro'
import Figure from '@components/Figure.astro'

type Props = CollectionEntry<'tutorials'>['data']

type Layout = 'wide' | 'standard'

const {
  title,
  description,
  pubDate,
  updateDate,
  updateNotes,
  author,
  cover,
  tags,
  isDraft,
  headings,
  layout = 'standard' as Layout,
  readingTime = { minutes: 0, words: 0 }
} = Astro.props as Props

const toc = true
const hasUpdateNotes = Boolean(updateNotes && updateNotes.length > 0)
const formattedUpdateDate = updateDate
  ? updateDate.toLocaleDateString('de-DE', {
      year: 'numeric',
      month: 'long',
      day: 'numeric'
    })
  : null
---

<BaseLayout
  title={title}
  description={description}
  headings={headings}
  toc={toc}
  layout={layout}
  cover={cover}
  author={author}
  tags={tags}
  pubDate={pubDate}
  updateDate={updateDate}
  ogType='article'
>
  {isDraft && <div class='draft-banner' />}

  <article class='article'>
    <header>
      <h1 style='view-transition-name: article-title;'>
        <Fragment set:html={formatTitle(title)} />
      </h1>

      <Lead text={description} />

      <ArticleMeta
        date={pubDate}
        updateDate={updateDate}
        hasUpdateNotes={hasUpdateNotes}
        author={author}
        readingTime={readingTime}
      />
    </header>

    {
      cover && (
        <Figure
          src={'image' in cover ? (cover as any).image : (cover as any).path}
          caption={cover.caption}
          alt={cover.alt}
          lazy={false}
        />
      )
    }

    <slot name='article' />

    {
      updateNotes && updateNotes.length > 0 && (
        <section
          id='update-notes'
          class='update-notes'
          aria-label='Neu im letzten Update'
        >
          <h2>Änderungen</h2>

          <p class='t-small t-light'>
            Veröffentlicht am
            <time datetime={pubDate.toISOString()}>
              {pubDate.toLocaleDateString('de-DE', {
                year: 'numeric',
                month: 'long',
                day: 'numeric'
              })}
            </time>
            {formattedUpdateDate && <> · Geändert: {formattedUpdateDate}</>}
          </p>

          <ul>
            {updateNotes.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </section>
      )
    }

    <Tags tags={tags as string[]} divider={true} />
  </article>

  <Fragment slot='sidebar'>
    <slot name='learning-path' />
  </Fragment>

  <Fragment slot='page-footer'>
    <slot name='related' />
  </Fragment>
</BaseLayout>

<style>
  .article {
    container: article / inline-size;
  }

  .draft-banner {
    position: fixed;
    inset: var(--header-height) 0 auto auto;
    z-index: 2;

    background-color: var(--clr-warning);
    color: var(--clr-inverse);
    pointer-events: none;
    inline-size: max-content;

    box-shadow: 0 0.3em 0.5em -0.3em rgb(0 0 0 / 0.6);

    &::after {
      display: block;
      text-align: center;
      padding-block: 0.8em 0.6em;
      padding-inline: var(--sp);
      line-height: 1;

      font-size: var(--fs-xs);
      font-weight: var(--fw-bold);

      content: 'Entwurf';
    }

    @media screen and (width >= 57.5em) {
      inset: calc(var(--header-height) + var(--sp-l)) auto auto 0;
      rotate: -90deg;
      transform: translateX(-100%);
      transform-origin: 0 0;
      box-shadow: -0.3rem 0 0.3rem -0.1em rgb(0 0 0 / 0.3);
    }
  }

  .update-notes {
    margin-block: var(--sp-content) 0;

    h2 {
      margin: 0 0 0.5em;
      font-family: var(--ff);
      font-size: var(--fs-s);
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--clr-text-light);
    }

    ul {
      margin: 0;
      padding-inline-start: 1.3rem;
      font-size: var(--fs-s);
      color: var(--clr-text-light);
    }

    li + li {
      margin-block-start: 0.35em;
    }
  }
</style>
