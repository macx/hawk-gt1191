---
import type { CollectionEntry } from 'astro:content'
import BaseLayout from './BaseLayout.astro'
import { formatTitle } from '@plugins/remark-widont.mjs'
import Lead from '@components/Lead.astro'
import ArticleMeta from '@components/ArticleMeta.astro'
import Tags from '@components/Tags.astro'
import Figure from '@components/Figure.astro'
import UpdateNotes from '@components/UpdateNotes.astro'

type Props = CollectionEntry<'tutorials'>['data']

type Layout = 'wide' | 'standard'

const {
  title,
  description,
  pubDate,
  updates = [],
  author,
  cover,
  tags,
  isDraft,
  headings,
  layout = 'standard' as Layout,
  readingTime = { minutes: 0, words: 0 }
} = Astro.props as Props

const toc = true
const hasUpdates = updates && updates.length > 0
const latestUpdateDate = hasUpdates
  ? updates.reduce((latest, cur) => {
      const curDate = typeof cur === 'object' && 'date' in cur ? cur.date : null
      if (!curDate) return latest
      return new Date(curDate) > new Date(latest) ? curDate : latest
    }, updates[0].date)
  : undefined
const formattedUpdateDate = latestUpdateDate
  ? new Date(latestUpdateDate).toLocaleDateString('de-DE', {
      year: 'numeric',
      month: 'long',
      day: 'numeric'
    })
  : null
const hasUpdateNotes = hasUpdates
const updatesByDate = updates.reduce(
  (map, item) => {
    const d = typeof item === 'object' && 'date' in item ? item.date : null
    const n = typeof item === 'object' && 'note' in item ? item.note : item
    if (!d) return map
    const key = new Date(d).toISOString().split('T')[0]
    if (!map[key]) map[key] = []
    map[key].push(n)
    return map
  },
  {} as Record<string, string[]>
)
---

<BaseLayout
  title={title}
  description={description}
  headings={headings}
  toc={toc}
  layout={layout}
  cover={cover}
  author={author}
  tags={tags}
  pubDate={pubDate}
  updateDate={latestUpdateDate}
  ogType='article'
>
  {isDraft && <div class='draft-banner' />}

  <article class='article'>
    <header>
      <h1 style='view-transition-name: article-title;'>
        <Fragment set:html={formatTitle(title)} />
      </h1>

      <Lead text={description} />

      <ArticleMeta
        date={pubDate}
        updateDate={latestUpdateDate ?? undefined}
        hasUpdateNotes={hasUpdateNotes}
        author={author}
        readingTime={readingTime}
      />
    </header>

    {
      cover && (
        <Figure
          src={'image' in cover ? (cover as any).image : (cover as any).path}
          caption={cover.caption}
          alt={cover.alt}
          lazy={false}
        />
      )
    }

    <slot name='article' />

    <UpdateNotes
      pubDate={pubDate}
      formattedUpdateDate={formattedUpdateDate}
      updatesByDate={updatesByDate}
    />

    <Tags tags={tags as string[]} divider={true} />
  </article>

  <Fragment slot='sidebar'>
    <slot name='learning-path' />
  </Fragment>

  <Fragment slot='page-footer'>
    <slot name='related' />
  </Fragment>
</BaseLayout>

<style>
  .article {
    container: article / inline-size;
  }

  .draft-banner {
    position: fixed;
    inset: var(--header-height) 0 auto auto;
    z-index: 2;

    background-color: var(--clr-warning);
    color: var(--clr-inverse);
    pointer-events: none;
    inline-size: max-content;

    box-shadow: 0 0.3em 0.5em -0.3em rgb(0 0 0 / 0.6);

    &::after {
      display: block;
      text-align: center;
      padding-block: 0.8em 0.6em;
      padding-inline: var(--sp);
      line-height: 1;

      font-size: var(--fs-xs);
      font-weight: var(--fw-bold);

      content: 'Entwurf';
    }

    @media screen and (width >= 57.5em) {
      inset: calc(var(--header-height) + var(--sp-l)) auto auto 0;
      rotate: -90deg;
      transform: translateX(-100%);
      transform-origin: 0 0;
      box-shadow: -0.3rem 0 0.3rem -0.1em rgb(0 0 0 / 0.3);
    }
  }
</style>
