---
import ArticleCard from '@components/ArticleCard.astro'

type CustomLink = {
  label: string
  href: string
}

type Termin = {
  title: string
  date: string
  startTime: string
  endTime: string
  description: string
  location: string
  recordingUrl?: string
  isNext?: boolean
  showZoom?: boolean
  showCode?: boolean
  showRecording?: boolean
  customLinks?: CustomLink[]
}

type CardLink = {
  label: string
  href: string
  kind: 'zoom' | 'archive' | 'custom'
}

interface Props {
  semester?: string
  zoomUrl?: string
  entries: Termin[]
}

const { semester = '', zoomUrl = '', entries = [] } = Astro.props

const sortedEntries = [...entries].sort(
  (a, b) => new Date(a.date).getTime() - new Date(b.date).getTime()
)

Astro.response.headers.set(
  'Cache-Control',
  'no-store, no-cache, must-revalidate, max-age=0'
)
---

{
  sortedEntries.length > 0 ? (
    <section>
      {semester && <h3>{semester}</h3>}

      <ul class='timeline' data-articles={sortedEntries.length}>
        {sortedEntries.map((entry) => {
          const eventDay = new Date(entry.date)
          const recordingHref = entry.recordingUrl ?? ''
          const links: CardLink[] = []
          const statusText = entry.showRecording ? 'Aufzeichnung verfügbar' : ''

          // Dynamic Links
          if (entry.showZoom && zoomUrl) {
            links.push({
              label: 'Zoom-Meeting (live)',
              href: zoomUrl,
              kind: 'zoom'
            })
          }

          if (entry.showRecording && recordingHref) {
            links.push({
              label: 'Aufzeichnung und Seminar-Quellcode',
              href: recordingHref,
              kind: 'archive'
            })
          } else if (entry.showCode && recordingHref) {
            links.push({
              label: 'Seminar-Quellcode',
              href: recordingHref,
              kind: 'archive'
            })
          }

          // Custom links
          if (entry.customLinks && entry.customLinks.length > 0) {
            links.push(
              ...entry.customLinks.map((customLink) => ({
                ...customLink,
                kind: 'custom' as const
              }))
            )
          }

          const months = [
            'Jan',
            'Feb',
            'Mär',
            'Apr',
            'Mai',
            'Jun',
            'Jul',
            'Aug',
            'Sep',
            'Okt',
            'Nov',
            'Dez'
          ]
          const calendarMonth = months[eventDay.getMonth()].toUpperCase()
          const calendarDay = eventDay.getDate()

          return (
            <li>
              <div class='calendar-block' aria-hidden='true'>
                <span class='calendar-block-month'>{calendarMonth}</span>
                <span class='calendar-block-day'>{calendarDay}</span>
              </div>
              <ArticleCard
                card={{
                  title: entry.title,
                  description: entry.description,
                  isTimelineCalendar: true,
                  meta: {
                    location: entry.location,
                    status: statusText,
                    statusType: entry.showRecording ? 'done' : ''
                  },
                  isActive: entry.isNext === true,
                  links,
                  showMore: false
                }}
              />
            </li>
          )
        })}
      </ul>
    </section>
  ) : (
    <p>Aktuell sind noch keine Termine eingetragen.</p>
  )
}
