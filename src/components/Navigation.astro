---
import { Icon } from 'astro-icon/components'
import ThemeButton from './ThemeButton.astro'

const pathname = new URL(Astro.request.url).pathname
const currentPath = pathname.split('/').slice(0, 2).join('').trim()

const { siteLinks } = Astro.props

// Get Pages for Navigation
const pages = Object.values(
  import.meta.glob('../pages/*.{mdx,astro}', { eager: true })
)

const filteredPages = pages
  .filter((page: any) => page.frontmatter.visible === true)
  .map((page: any) => ({
    url: page.url,
    title: page.frontmatter.navTitle,
    sort: page.frontmatter.sort || 99
  }))

const allPages = [
  ...filteredPages,
  { url: '/tutorials', title: 'Tutorials', sort: 2 }
].sort((a: any, b: any) => (a.sort > b.sort ? 1 : -1))
---

<nav id='main-navigation' aria-label='Hauptnavigation' class='navigation'>
  <template id='main-nav-button'>
    <button
      type='button'
      class='navigation-toggle js-toggle-nav'
      aria-label='Navigation öffnen'
      aria-controls='main-navigation'
      aria-expanded='false'
    >
      <svg viewBox='0 0 24 24' aria-hidden='true' class='nav-icon'>
        <path d='M4 6h16' class='line top'></path>
        <path d='M4 12h16' class='line middle'></path>
        <path d='M4 18h16' class='line bottom'></path>
      </svg>
      <span class='sr-only js-toggle-label'>Navigation öffnen</span>
    </button>
  </template>

  <div class='navigation-items'>
    <ul>
      <li class='home'>
        <a
          href='/'
          class:list={[{ current: `/${currentPath}` === '/' }]}
          aria-current={`/${currentPath}` === '/' ? 'page' : undefined}
        >
          Das Seminar
        </a>
      </li>
      {
        allPages.map((page: any) => (
          <li>
            <a
              href={page.url}
              class:list={[{ current: `/${currentPath}` === page.url || currentPath === page.url.replace('/', '') }]}
              aria-current={`/${currentPath}` === page.url || currentPath === page.url.replace('/', '') ? 'page' : undefined}
            >
              {page.title}
            </a>
          </li>
        ))
      }
    </ul>
  </div>

  <ul class='links'>
    <li class='external'>
      <a
        href={siteLinks.discord}
        target='_blank'
        rel='noopener'
        class='header-button'
      >
        <Icon name='simple-icons:discord' aira-hidden='true' />
        <span class='sr-only'>Discord</span>
      </a>
    </li>
    <li class='external'>
      <a
        href={siteLinks.studip}
        target='_blank'
        rel='noopener'
        class='header-button'
        aria-label='Stud-IP - Studentische Informationsplattform'
      >
        <Icon name='studip' aira-hidden='true' />
        <span class='sr-only'>Stud-IP</span>
      </a>
    </li>
    <li class='external'>
      <a
        href={siteLinks.github}
        target='_blank'
        rel='noopener'
        class='header-button'
      >
        <Icon name='simple-icons:github' aira-hidden='true' />
        <span class='sr-only'>GitHub</span>
      </a>
    </li>
    <li class='divider'></li>
    <li>
      <ThemeButton />
    </li>
    <li>
      <a href='#top' class='header-button' title='Nach oben scrollen'>
        <Icon name='material-symbols:arrow-upward-rounded' />
      </a>
    </li>
  </ul>
</nav>

<style>
  .navigation {
    @media screen and (width < 57.5em) {
      position: fixed;
      inset-block-start: var(--header-height);
      inset-inline: 0;
      block-size: auto;
      max-block-size: calc(100dvh - var(--header-height));
      z-index: 20;

      display: flex;
      flex-direction: column;

      backdrop-filter: blur(px);
      overflow: auto;
      transform-origin: top right;
      will-change: clip-path, transform, opacity;
      transition:
        clip-path 620ms cubic-bezier(0.22, 1, 0.36, 1),
        transform 620ms cubic-bezier(0.22, 1, 0.36, 1),
        opacity 320ms ease-out;
    }

    .links {
      border-block-start: 1px solid var(--clr-line-dark);
      border-block-end: 1px solid var(--clr-line-dark);
    }
  }

  /* Progressive Enhancement: Nav nur verstecken, wenn der Toggle-Button per JS eingefügt wurde */
  :global(.js-toggle-nav ~ .navigation) {
    @media screen and (width < 57.5em) {
      opacity: 0;
      pointer-events: none;
      transform: translateY(-0.5rem) scale(0.98);
      clip-path: circle(
        0 at calc(100% - (var(--header-height) / 2))
          calc(var(--header-height) / 2)
      );
    }
  }

  :global(.js-toggle-nav[aria-expanded='true'] ~ .navigation) {
    @media screen and (width < 57.5em) {
      opacity: 1;
      pointer-events: auto;
      transform: translateY(0) scale(1);
      clip-path: circle(
        150vmax at calc(100% - (var(--header-height) / 2))
          calc(var(--header-height) / 2)
      );
    }
  }

  @supports (top: anchor(--main-nav-toggle bottom)) {
    :global(.js-toggle-nav ~ .navigation) {
      @media screen and (width < 57.5em) {
        clip-path: circle(
          0 at anchor(--main-nav-toggle right) anchor(--main-nav-toggle center)
        );
      }
    }

    :global(.js-toggle-nav[aria-expanded='true'] ~ .navigation) {
      @media screen and (width < 57.5em) {
        clip-path: circle(
          150vmax at anchor(--main-nav-toggle right)
            anchor(--main-nav-toggle center)
        );
      }
    }
  }

  /* Toggle-Button: global, da dynamisch per JS injiziert */
  :global(.navigation-toggle) {
    all: unset;

    display: grid;
    place-items: center;
    position: relative;
    z-index: 21;

    padding-inline: var(--sp-xs);
    block-size: var(--header-height);
    cursor: pointer;
    transition: background-color var(--transition);
    margin-inline-end: calc((var(--sp-content) / 2) * -1);

    &:hover,
    &:focus-visible {
      background-color: var(--clr-primary--hover);
    }

    &:focus-visible {
      outline: 3px dotted var(--clr-primary);
      outline-offset: 2px;
      outline-style: dotted;
      box-shadow: 0 0 0 3px var(--clr-inverse);
    }

    @media screen and (width >= 57.5em) {
      display: none;
    }

    @media screen and (width < 57.5em) {
      anchor-name: --main-nav-toggle;
    }
  }

  /* Hamburger-Icon */
  :global(.nav-icon) {
    inline-size: var(--icon-size);
    block-size: var(--icon-size);

    .line {
      fill: none;
      stroke: var(--clr-text);
      stroke-width: 2;
      stroke-linecap: round;
      stroke-linejoin: round;
      transition:
        stroke var(--transition),
        transform 200ms ease,
        opacity 200ms ease;
    }
  }

  :global(.js-toggle-nav[aria-expanded='true'] .nav-icon) {
    .top {
      transform: rotate(45deg) translate(5px, -6px);
      transform-origin: 0 0;
    }

    .middle {
      opacity: 0;
    }

    .bottom {
      transform: rotate(-45deg) translate(0, -6px);
      transform-origin: 50% 50%;
    }
  }

  @media screen and (width < 57.5em) {
    :global(body::before) {
      content: '';
      position: fixed;
      inset: var(--header-height) 0 0 0;
      z-index: 19;
      opacity: 0;
      pointer-events: none;
      backdrop-filter: blur(10px);
      background-color: rgb(0 0 0 / 10%);
      transition: opacity 260ms ease;
    }

    :global(body.nav-open) {
      overflow: hidden;
      overscroll-behavior: none;
      touch-action: none;
    }

    :global(body.nav-open::before) {
      opacity: 1;
    }
  }

  .links {
    display: flex;
    justify-content: space-around;
    align-items: center;

    padding-inline-start: 0;
    list-style: none;
    margin-block: 0;
    background-color: var(--clr-bg);

    .divider {
      border-inline-start: 1px solid var(--clr-line);
      padding-inline-start: var(--sp);
      width: 1px;
      height: 100%;
    }

    a {
      display: grid;
      place-items: center;
      block-size: var(--header-height);
      inline-size: var(--header-height);
      color: currentColor;
    }

    svg {
      display: block;
      width: var(--icon-size);
      height: var(--icon-size);
      fill: var(--clr-text);
      transition: fill var(--transition);
    }

    @media screen and (width >= 57.5em) {
      display: none;
    }
  }

  .navigation-items {
    ul {
      margin-block: 0;
      padding-inline-start: 0;
    }

    li {
      list-style: none;
    }

    a {
      position: relative;
      display: flex;
      justify-content: center;
      align-items: center;
      background: none;
      color: var(--clr-text);
      text-decoration: none;

      &:hover,
      &:focus-visible {
        background-color: transparent;
        color: var(--clr-link);
      }

      &.current {
        font-weight: var(--fw-bold);
        color: var(--clr-link);
      }
    }

    @media screen and (width < 57.5em) {
      background-color: var(--clr-bg-nav);
      flex: 0 0 min(100%, 15vh);
      padding-block: var(--sp-l);

      a {
        font-size: var(--fs-l);
        color: var(--clr-text);
        padding-inline: var(--sp-content);
        padding-block: var(--sp-xs);
        justify-content: center;

        &.current {
          font-weight: var(--fw-bold);
          color: var(--clr-link);
        }
      }

      :global([data-theme='dark']) a {
        &:hover,
        &:focus {
          color: var(--clr-inverse);
        }
      }
    }

    @media screen and (37.5em <= width < 57.5em) {
      padding-inline: var(--sp-content);

      ul {
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        column-gap: var(--sp);
        row-gap: var(--sp-xs);
      }

      a {
        padding-inline: 0;
        padding-block: 0;
      }
    }

    @media screen and (width >= 57.5em) {
      ul {
        display: flex;
        justify-content: flex-start;
        align-items: center;
        padding: 0 0 0 var(--sp-s);
      }

      li.home {
        display: none;
      }

      a {
        height: var(--header-height);
        padding-inline: 1ch;

        &::after {
          display: inline-block;
          content: '';
          position: absolute;
          left: 50%;
          bottom: 0;
          width: 0;
          height: 2px;
          z-index: 2;
          transform: translateX(-50%);
          background-color: var(--clr-link);
          transition: width 120ms ease-in-out;
        }

        &:hover,
        &:focus {
          &::after {
            width: calc(100% - 2rem);
          }
        }
      }
    }
  }
</style>

<script>
  const navigation = document.querySelector<HTMLElement>('.navigation')
  const navButtonTpl =
    document.querySelector<HTMLTemplateElement>('#main-nav-button')

  if (navigation && navButtonTpl) {
    const clone = navButtonTpl.content.cloneNode(true) as DocumentFragment
    const navButton = clone.querySelector<HTMLButtonElement>('button')!

    // Button vor der Navigation einfügen – so greift der CSS-Sibling-Selektor
    navigation.parentElement?.insertBefore(clone, navigation)

    const setNavigationState = (isOpen: boolean) => {
      navButton.setAttribute('aria-expanded', String(isOpen))
      navButton.setAttribute(
        'aria-label',
        isOpen ? 'Navigation schließen' : 'Navigation öffnen'
      )
      document.body.classList.toggle('nav-open', isOpen)

      const label = navButton.querySelector('.js-toggle-label')

      if (label) {
        label.textContent = isOpen
          ? 'Navigation schließen'
          : 'Navigation öffnen'
      }
    }

    navButton.addEventListener('click', () => {
      setNavigationState(navButton.getAttribute('aria-expanded') !== 'true')
    })

    navigation.addEventListener('click', (event) => {
      if (event.target !== event.currentTarget) return
      setNavigationState(false)
    })

    document.querySelector('[href="#top"]')?.addEventListener('click', () => {
      setNavigationState(false)
    })
  }
</script>
