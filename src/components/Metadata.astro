---
import { getEntry } from 'astro:content'
import { SITE_CONST } from '../const.ts'

// Remove trailing slash from URL
// https://noahflk.com/blog/trailing-slashes-astro
function removeTrailingSlash(str: string) {
  return str.replace(/\/+$/, '')
}

interface Props {
  title: string
  description: string
  image?: string
  canonicalUrl?: string
  type?: 'website' | 'article'
  pubDate?: string | Date
  updateDate?: string | Date
  author?: { id?: string }
  tags?: string[]
  redirect?: boolean
}

const {
  title,
  description,
  type = 'website',
  pubDate,
  updateDate,
  author,
  tags,
  redirect
} = Astro.props

const canonicalUrl = removeTrailingSlash(
  new URL(Astro.url.pathname, Astro.site).toString().toLowerCase()
)

const openGraphImage = Astro.url.pathname.startsWith('/tutorials')
  ? new URL(`${canonicalUrl}/og.png`, Astro.url)
  : new URL('images/website-cover.png', Astro.url)

const datePublished = pubDate ? new Date(pubDate).toISOString() : undefined
const dateModified = updateDate ? new Date(updateDate).toISOString() : undefined
const keywords = tags?.length ? tags.join(', ') : undefined
const isTutorial = Astro.url.pathname.startsWith('/tutorials')

const authorProfile = author?.id ? await getEntry('authors', author.id) : null

const publisher = {
  '@type': 'Organization',
  name: SITE_CONST.title,
  url: SITE_CONST.site
}

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${SITE_CONST.site}#website`,
  url: SITE_CONST.site,
  name: SITE_CONST.title,
  description: SITE_CONST.description,
  inLanguage: 'de-DE'
}

const articleJsonLd =
  type === 'article' && datePublished
    ? {
        '@context': 'https://schema.org',
        '@type': isTutorial ? 'TechArticle' : 'Article',
        '@id': `${canonicalUrl}#article`,
        headline: title,
        description,
        datePublished,
        dateModified: dateModified || datePublished,
        mainEntityOfPage: {
          '@type': 'WebPage',
          '@id': canonicalUrl
        },
        url: canonicalUrl,
        image: openGraphImage?.href,
        inLanguage: 'de-DE',
        articleSection: isTutorial ? 'Tutorial' : undefined,
        keywords,
        about: tags?.length ? tags : undefined,
        isPartOf: {
          '@id': `${SITE_CONST.site}#website`
        },
        author: authorProfile
          ? {
              '@type': 'Person',
              name: authorProfile.data.name
            }
          : undefined,
        publisher
      }
    : null

const breadcrumbJsonLd =
  isTutorial && title
    ? {
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: [
          {
            '@type': 'ListItem',
            position: 1,
            name: 'Startseite',
            item: SITE_CONST.site
          },
          {
            '@type': 'ListItem',
            position: 2,
            name: 'Tutorials',
            item: `${SITE_CONST.site}/tutorials`
          },
          {
            '@type': 'ListItem',
            position: 3,
            name: title,
            item: canonicalUrl
          }
        ]
      }
    : null
---

<!-- Global Metad -->
<meta charset='utf-8' />
<meta name='color-scheme' content='dark light' />
<meta name='viewport' content='width=device-width, initial-scale=1.0' />
<link rel='canonical' href={canonicalUrl} />
{redirect ? <meta http-equiv='refresh' content='0;url=/404' /> : null}

<!-- Primary Meta -->
<title>{title} | {SITE_CONST.title}</title>
<meta name='description' content={description} />
<meta name='robots' content='index,follow,max-image-preview:large' />
{keywords && <meta name='keywords' content={keywords} />}
{
  datePublished && (
    <meta property='article:published_time' content={datePublished} />
  )
}
{
  dateModified && (
    <meta property='article:modified_time' content={dateModified} />
  )
}
{tags?.map((tag) => <meta property='article:tag' content={tag} />)}

<!-- Icons -->
<link rel='apple-touch-icon' sizes='180x180' href='/apple-touch-icon.png' />
<link rel='icon' type='image/png' sizes='32x32' href='/favicon-32x32.png' />
<link rel='icon' type='image/png' sizes='16x16' href='/favicon-16x16.png' />
<link rel='icon' type='image/svg+xml' href='/favicon.svg' />

<link rel='manifest' href='/app.webmanifest' />
<meta name='msapplication-TileColor' content='#da532c' />
<meta name='theme-color' content='#ffffff' />

<link
  rel='alternate'
  type='application/rss+xml'
  title='RSS Feed'
  href='/rss.xml'
/>
<link rel='sitemap' href='/sitemap-index.xml' />

<!-- Open Graph / Facebook -->
<meta property='og:title' content={title + ' | ' + SITE_CONST.title} />
<meta property='og:description' content={description} />
<meta property='og:url' content={canonicalUrl} />
<meta property='og:type' content={type} />
{
  openGraphImage && (
    <>
      <meta property='og:image' content={openGraphImage.href} />
      <meta property='og:image:alt' content={title} />
    </>
  )
}

{
  websiteJsonLd && (
    <script
      type='application/ld+json'
      set:html={JSON.stringify(websiteJsonLd)}
    />
  )
}

{
  articleJsonLd && (
    <script
      type='application/ld+json'
      set:html={JSON.stringify(articleJsonLd)}
    />
  )
}

{
  breadcrumbJsonLd && (
    <script
      type='application/ld+json'
      set:html={JSON.stringify(breadcrumbJsonLd)}
    />
  )
}

<script is:inline>
  ;(function () {
    const mode = localStorage.getItem('data-theme')
    const prefersScheme = window.matchMedia('(prefers-color-scheme: dark)')
      .matches
      ? 'dark'
      : 'light'

    if (mode) {
      document.documentElement.setAttribute(
        'data-theme',
        mode === 'system' ? prefersScheme : mode
      )
      document.documentElement.setAttribute(
        'data-code-theme',
        mode === 'system'
          ? prefersScheme === 'dark'
            ? 'catppuccin-frappe'
            : 'catppuccin-latte'
          : mode === 'dark'
            ? 'catppuccin-frappe'
            : 'catppuccin-latte'
      )
    } else {
      document.documentElement.setAttribute('data-theme', prefersScheme)
      document.documentElement.setAttribute(
        'data-code-theme',
        prefersScheme === 'dark' ? 'catppuccin-frappe' : 'catppuccin-latte'
      )
    }
  })()
</script>
