---
import type { ImageMetadata } from 'astro'
import { render } from 'astro:content'
import { Image } from 'astro:assets'
import { Icon } from 'astro-icon/components'
import { formatTitle, widont } from '@plugins/remark-widont.mjs'
import FormattedDate from './FormattedDate.astro'

type CardLink = {
  href: string
  label: string
  kind?: 'zoom' | 'archive' | 'custom'
}

const { article, card } = Astro.props
const isContentArticle = Boolean(article)
const title = card?.title ?? article?.data?.title
const description = card?.description ?? article?.data?.description
const href = card?.href ?? (article ? `/tutorials/${article.id}` : undefined)
const coverPath = card?.imagePath ?? article?.data?.cover?.path
const coverAlt = card?.imageAlt ?? article?.data?.cover?.alt ?? coverPath
const coverImage = article?.data?.cover?.image
const cardPubDate = card?.pubDate ? new Date(card.pubDate) : undefined
const cardMeta = card?.meta
const isActive = card?.isActive === true
const showMore = card?.showMore ?? true
const moreLabel = card?.moreLabel ?? 'Weiterlesen'
const moreKind = card?.moreKind
const cardLinks: CardLink[] =
  card?.links?.filter(
    (link: { href?: string; label?: string }) =>
      Boolean(link?.href) && Boolean(link?.label)
  ) ?? []
const hasLink = Boolean(href)
const WrapperTag = hasLink ? 'a' : 'div'
const wrapperProps = hasLink ? { href } : {}
const isDraft = article?.data?.isDraft
const safeTitle = title ?? ''
const safeDescription = description ?? ''
const safeAlt = coverAlt ?? safeTitle

const images = import.meta.glob<{ default: ImageMetadata }>(
  '/src/images/**/*.{jpeg,jpg,png}'
)
let readingTime: { minutes: number; words: number } | undefined
let pubDate: Date | undefined

if (isContentArticle) {
  const { remarkPluginFrontmatter } = await render(article as never)
  const minutesToRead = remarkPluginFrontmatter.minutesToRead
  readingTime = {
    minutes: Number(minutesToRead.minutes.toFixed(0)),
    words: minutesToRead.words
  }
  pubDate = article.data.pubDate
}

if (!pubDate && cardPubDate && !Number.isNaN(cardPubDate.getTime())) {
  pubDate = cardPubDate
}

const hasMeta = Boolean(pubDate)
const hasImage = Boolean(coverImage || coverPath)
const hasMetaRow = Boolean(pubDate || cardMeta?.location || cardMeta?.status)

if (coverPath && !images[coverPath] && !coverImage) {
  throw new Error(
    `Das Bild "${coverPath}" existiert im angegeben Verzeichnis nicht.`
  )
}
---

<article
  class:list={[
    'article-card',
    'media-item-article',
    {
      draft: isDraft,
      'has-meta': hasMeta,
      'has-image': hasImage,
      'is-timeline-calendar': card?.isTimelineCalendar === true,
      'is-active': isActive,
      'is-link': hasLink
    }
  ]}
  data-article-id={article?.id}
>
  {isDraft && <div class='draft-banner' />}

  <WrapperTag class='card-shell' {...wrapperProps}>
    <header>
      <h3 class='title'>
        <Fragment set:html={formatTitle(safeTitle)} />
      </h3>

      {
        hasMetaRow ? (
          <div class='meta-row'>
            {pubDate && (
              <FormattedDate
                date={pubDate}
                readingTime={readingTime?.minutes ?? 0}
              />
            )}

            {cardMeta?.location && (
              <span class='meta-item'>
                <svg
                  aria-hidden='true'
                  viewBox='0 0 24 24'
                  width='18'
                  height='18'
                  focusable='false'
                >
                  <path
                    fill='currentColor'
                    d='M12 2a7 7 0 0 1 7 7c0 4.37-5.25 10.9-6.27 12.12a1 1 0 0 1-1.46 0C10.25 19.9 5 13.37 5 9a7 7 0 0 1 7-7m0 9.5A2.5 2.5 0 1 0 12 6a2.5 2.5 0 0 0 0 5.5'
                  />
                </svg>
                <span>{cardMeta.location}</span>
              </span>
            )}

            {cardMeta?.status && (
              <span
                class:list={[
                  'meta-tag',
                  {
                    'meta-tag-done': cardMeta.statusType === 'done',
                    'meta-tag-today': cardMeta.statusType === 'today'
                  }
                ]}
              >
                {cardMeta.status}
              </span>
            )}
          </div>
        ) : null
      }
    </header>

    {
      hasImage ? (
        <div class='image'>
          {coverImage ? (
            <Image
              src={coverImage}
              widths={[380, 670, 710]}
              sizes={`(max-width: 480px) 380px, (max-width: 800) 670px, 710px`}
              alt={safeAlt}
            />
          ) : (
            coverPath && (
              <Image
                src={images[coverPath]()}
                widths={[380, 670, 710]}
                sizes={`(max-width: 480px) 380px, (max-width: 800) 670px, 710px`}
                alt={safeAlt}
              />
            )
          )}
        </div>
      ) : null
    }

    <div class='description'>
      <p>{widont(safeDescription)}</p>

      {
        showMore && hasLink && (
          <span class:list={['more', { zoom: moreKind === 'zoom' }]}>
            {moreKind === 'zoom' && (
              <svg
                aria-hidden='true'
                viewBox='0 0 24 24'
                width='16'
                height='16'
                focusable='false'
              >
                <path
                  fill='currentColor'
                  d='M15 8a1 1 0 0 1 .62.22l4.5 3.6a1 1 0 0 1 0 1.56l-4.5 3.6A1 1 0 0 1 14 16.2v-1.7H6a2 2 0 0 1-2-2V11.5a2 2 0 0 1 2-2h8V7.8A1 1 0 0 1 15 8m-1 2.5H6v2h8a1 1 0 0 1 1 1v.62L17.9 12L15 9.88v.62a1 1 0 0 1-1 1Z'
                />
              </svg>
            )}
            {moreLabel}
          </span>
        )
      }

      {
        cardLinks.length > 0 && (
          <>
            <h4>Links:</h4>

            <ul class='card-links' aria-label='Zusatzlinks zum Seminartermin'>
              {cardLinks.map((link) => (
                <li>
                  <a
                    class:list={['more', 'card-link']}
                    href={link.href}
                    target='_blank'
                    rel='noopener noreferrer'
                  >
                    {link.kind === 'zoom' ? (
                      <Icon
                        name='material-symbols:videocam-outline-rounded'
                        aria-hidden='true'
                        class='card-link-icon'
                      />
                    ) : link.kind === 'archive' ? (
                      <Icon
                        name='material-symbols:folder-open-outline-rounded'
                        aria-hidden='true'
                        class='card-link-icon'
                      />
                    ) : (
                      <span
                        class='card-link-icon card-link-dot'
                        aria-hidden='true'
                      />
                    )}
                    <span class='card-link-label'>{link.label}</span>
                  </a>
                </li>
              ))}
            </ul>
          </>
        )
      }
    </div>
  </WrapperTag>
</article>

<style>
  .article-card {
    margin-block: 0;
    position: relative;
    transition: box-shadow var(--transition);
    container: article-card / inline-size;

    &.is-timeline-calendar.is-active {
      background-color: color-mix(
        in oklab,
        var(--clr-bg-card),
        var(--clr-success) 18%
      );
      border-color: color-mix(
        in oklab,
        var(--clr-success),
        var(--clr-line) 40%
      );
      box-shadow: 0 0.53em 1em -0.5rem rgb(20 130 72 / 22%);
    }

    &.is-timeline-calendar.is-active .card-shell {
      background-color: transparent;
    }

    &:hover,
    &.focus {
      box-shadow: 0 0.53em 1em -0.5rem rgba(0, 0, 0, 0.2);
    }

    .card-shell {
      display: flex;
      flex-direction: column;
      color: var(--clr-text);
      text-decoration: none;
      min-height: 100%;

      .image + .description {
        padding-block-start: var(--sp);
      }
    }

    &.is-link .card-shell {
      &:hover,
      &:focus {
        color: currentColor;
        text-decoration: none;

        .title,
        .more {
          color: var(--clr-link);
        }

        .more {
          display: inline-flex;
          align-items: center;
        }

        .more::after {
          transform: translate(0, -0.1em);
          scale: 2;
          opacity: 1;
        }

        .image img {
          scale: 1.1;
        }
      }
    }

    header {
      padding: var(--sp);
      grid-area: header;
    }

    .meta-row {
      margin-block-start: 0.35em;
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.5rem 1rem;
    }

    .meta-item {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-size: var(--fs-s);
      color: var(--clr-text-light);

      svg {
        inline-size: 1.125rem;
        block-size: 1.125rem;
        color: var(--clr-text-light);
        flex: 0 0 auto;
      }
    }

    .meta-tag {
      display: inline-flex;
      align-items: center;
      border-radius: 999rem;
      padding: 0.15rem 0.55rem;
      font-size: var(--fs-xs);
      font-weight: var(--fw-bold);
      line-height: 1.2;
    }

    .meta-tag-done {
      background: color-mix(in oklab, var(--clr-success), white 82%);
      color: color-mix(in oklab, var(--clr-success), black 25%);
    }

    .meta-tag-today {
      background: color-mix(in oklab, var(--clr-warning), white 85%);
      color: color-mix(in oklab, var(--clr-warning), black 30%);
    }

    .title {
      font-size: 1.3rem;
      font-family: var(--ff);
      margin-block: 0 0.5em;
      transition: all var(--transition);
    }

    .image {
      overflow: hidden;
      aspect-ratio: 16 / 9;

      img {
        grid-area: image;
        width: 100%;
        height: 100%;
        object-fit: cover;
        scale: 1;
        transition: var(--transition);
      }
    }

    .description {
      font-size: var(--fs-s);
      padding-block: 0 var(--sp);
      padding-inline: var(--sp);
      grid-area: description;
      flex: 1;
    }

    &.is-timeline-calendar {
      header,
      .description {
        padding-inline-start: 1.75rem;
      }

      .description p {
        margin-block-end: 0;
      }
    }

    .more {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      transition: all var(--transition);

      &::after {
        content: '»';
        margin-inline-start: 1ch;
        transform: translateX(-5ch);
        transition: all var(--transition);
        opacity: 0;
      }
    }

    .more.zoom {
      svg {
        inline-size: 1rem;
        block-size: 1rem;
      }

      &::after {
        display: none;
      }
    }

    h4 {
      margin-block: var(--sp) 0.5em;
    }

    .card-links {
      list-style: none;
      padding-inline-start: 0;
      margin-block: 0;
      margin-inline: 0;
      line-height: var(--lh-s);
    }

    .card-links li {
      margin-block: 0;

      & + li {
        margin-block-start: 0.5em;
      }
    }

    .card-link {
      display: flex;
      align-items: center;
      gap: 1.25ch;
      color: currentColor;
      text-decoration: none;

      &:link,
      &:visited {
        color: currentColor;
      }

      &:hover,
      &:focus-visible {
        color: var(--clr-link);
        text-decoration: none;
      }
    }

    .card-link.more::after {
      margin-inline-start: 0.25ch;
      transform: translateX(-1ch);
    }

    .card-link.more:hover::after,
    .card-link.more:focus-visible::after {
      transform: translate(0, -0.1em);
      scale: 2;
      opacity: 1;
    }

    .card-link-icon {
      inline-size: 1rem;
      block-size: 1rem;
      flex: 0 0 1rem;
      color: var(--clr-link);
    }

    .card-link-dot {
      --dot-size: 0.35em;

      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--clr-link);

      &::before {
        content: '';
        display: block;
        inline-size: var(--dot-size);
        block-size: var(--dot-size);
        border-radius: 50%;
        background-color: currentColor;
      }
    }

    .card-link-label {
      display: inline;
    }

    &:not(.has-meta) {
      header {
        padding-block-end: var(--sp);
      }

      .title {
        margin-block-end: 0;
      }
    }

    &.has-meta {
      .title {
        min-height: 2lh;
      }
    }

    @container article-card (width < 20em) {
      &.has-meta {
        .title {
          min-height: 3lh;
        }
      }
    }

    @container timeline (width > 32em) {
      &.has-image > .card-shell {
        display: grid;
        grid-template-areas:
          'image header'
          'image description';
        grid-template-columns: 30cqi auto;
        grid-template-rows: auto 1fr;
        column-gap: var(--sp-m);
        row-gap: var(--sp);
        padding: var(--sp);

        header {
          grid-area: header;
          padding: 0;
        }

        .description {
          grid-area: description;
          padding: 0;
        }

        .image {
          grid-area: image;
        }
      }
    }

    @container aside (width < 25em) {
      &:first-child {
        border-block-end-width: 0;
        border-end-end-radius: 0;
        border-end-start-radius: 0;
      }

      &:not(:last-child):not(:first-child) {
        border-radius: 0;
      }

      &:last-child {
        border-block-start-width: 0;
        border-start-start-radius: 0;
        border-start-end-radius: 0;
      }

      header {
        order: 2;
      }

      .title {
        font-size: 1rem;
        min-height: unset;
      }

      .image {
        order: 1;
      }

      .description {
        display: none;
        padding-block-start: 0;
      }
    }
  }

  .draft-banner {
    position: absolute;
    inset-block-start: -0.2em;
    inset-inline-end: 0.5em;
    z-index: 2;
    pointer-events: none;

    background-color: var(--clr-warning);
    color: var(--clr-inverse);
    box-shadow: 0 0.2em 0.3em -0.2em rgb(0 0 0 / 0.6);

    &::after {
      display: block;
      text-align: center;
      padding-block: 0.4em;
      padding-inline: 1.7ch;
      line-height: 1;

      font-size: var(--fs-xs);
      font-weight: var(--fw-bold);

      content: 'Entwurf';
    }
  }
</style>
