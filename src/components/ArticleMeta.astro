---
import { getEntry } from 'astro:content'
import FormattedDate from '@components/FormattedDate.astro'

interface Props {
  date: Date
  updateDate?: Date
  hasUpdateNotes?: boolean
  author: {
    id: string
    [key: string]: any
  }
  readingTime: {
    minutes: number
    words: number
  }
}

const {
  date,
  updateDate,
  hasUpdateNotes = false,
  author,
  readingTime
} = Astro.props
const authorProfile = await getEntry('authors', author.id)
---

<div class='meta'>
  {
    authorProfile && (
      <div class='byline'>
        Von{' '}
        <a href='/profil/david-maciejewski' rel='author'>
          {authorProfile.data.name}
        </a>
      </div>
    )
  }

  <FormattedDate
    date={date}
    updateDate={updateDate}
    hasUpdateNotes={hasUpdateNotes}
    readingTime={readingTime.minutes}
    wordCount={readingTime.words}
  />
</div>

<style>
  .meta {
    margin-block-end: var(--sp-m);
  }

  .byline :any-link {
    color: var(--clr-link);
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.12em;
  }
</style>
