---
const pathname = new URL(Astro.request.url).pathname
const currentPath = pathname.split('/').slice(3).join('').trim()

interface LearnPath {
  title: string
  slug: string
}

export interface Props {
  entries: LearnPath[]
}

const { entries } = Astro.props
---

<nav>
  <ul class='switch'>
    {
      entries.map(
        (entry) =>
          entry.slug && (
            <li>
              <a
                href={`/tutorials/lernpfade/${entry.slug}`}
                data-slug={entry.slug}
                class:list={[currentPath === entry.slug ? 'current' : null]}
                aria-current={currentPath === entry.slug ? 'page' : undefined}
              >
                {entry.title}
              </a>
            </li>
          )
      )
    }
  </ul>
</nav>

<style>
  .switch {
    --sw-radius: var(--radius);
    --sw-padding-block-start: 0.25rem;
    --sw-padding-block-end: 0.5rem;
    --sw-padding-inline: 1rem;

    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    padding: 0;
    margin-block: 0 var(--sp);
    gap: 0.65rem;

    li {
      list-style: none;
      margin-block: 0;
    }

    a {
      --path-accent: var(--clr-primary);
      display: block;
      padding-block: var(--sw-padding-block-start) var(--sw-padding-block-end);
      padding-inline: var(--sw-padding-inline);
      border-radius: var(--sw-radius);
      border: 1px solid
        color-mix(in oklab, var(--path-accent) 40%, var(--clr-line));
      background-color: color-mix(
        in oklab,
        var(--path-accent) 16%,
        var(--clr-bg-card)
      );
      text-decoration: none;
      text-align: center;
      color: var(--clr-text);
      font-weight: var(--fw);
      transition:
        color var(--transition),
        border-color var(--transition),
        background-color var(--transition);

      &[data-slug='einfuehrung'] {
        --path-accent: var(--clr-learning-path-1-accent);
      }

      &[data-slug='grundlagen'] {
        --path-accent: var(--clr-learning-path-2-accent);
      }

      &[data-slug='gestaltung'] {
        --path-accent: var(--clr-learning-path-3-accent);
      }

      &[data-slug='techniken'] {
        --path-accent: var(--clr-learning-path-4-accent);
      }

      &:hover,
      &:focus-visible {
        color: var(--clr-text);
        border-color: var(--path-accent);
        background-color: color-mix(
          in oklab,
          var(--path-accent) 24%,
          var(--clr-bg-card)
        );
      }

      &.current {
        border-color: var(--path-accent);
        background-color: color-mix(
          in oklab,
          var(--path-accent) 24%,
          var(--clr-bg-card)
        );
        color: var(--clr-text);
      }
    }
  }
</style>
