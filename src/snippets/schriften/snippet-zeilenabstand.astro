---
import Snippet from '@components/Snippet.astro'
---

<Snippet title='Interaktive Demo'>
  <Fragment slot='settings'>
    <div class='sn-settings'>
      <div class='sn-value'>
        <label for='el-fs-input' class='code'>font-size:</label>
        <input
          type='range'
          name='size'
          id='el-fs-input'
          min='0.8'
          max='2.0'
          step='0.2'
          value='1'
          list='el-fs-markers'
        />
        <span>
          <output id='el-fs-output' class='code'>1rem</output>
        </span>

        <datalist id='el-fs-markers'>
          <option value='0.8'></option>
          <option value='1.0'></option>
          <option value='1.2'></option>
          <option value='1.4'></option>
          <option value='1.6'></option>
          <option value='1.8'></option>
          <option value='2.0'></option>
        </datalist>
      </div>

      <div class='sn-value'>
        <label for='el-lh-input' class='code'>line-height:</label>
        <input
          type='range'
          name='size'
          id='el-lh-input'
          min='1.0'
          max='2.0'
          step='0.1'
          value='1.4'
          list='el-lh-markers'
        />
        <span>
          <output id='el-lh-output' class='code'>1.4</output>
        </span>

        <datalist id='el-lh-markers'>
          <option value='1.0'></option>
          <option value='1.1'></option>
          <option value='1.2'></option>
          <option value='1.3'></option>
          <option value='1.4'></option>
          <option value='1.5'></option>
          <option value='1.6'></option>
          <option value='1.7'></option>
          <option value='1.8'></option>
          <option value='1.9'></option>
          <option value='2.0'></option>
        </datalist>
      </div>

      <div class='sn-value'>
        <label for='el-ls-input' class='code'>letter-spacing:</label>
        <input
          type='range'
          name='size'
          id='el-ls-input'
          min='-0.025'
          max='0.200'
          step='0.025'
          value='0.050'
          list='el-ls-markers'
        />
        <span>
          <output id='el-ls-output' class='code'>0.05em</output>
        </span>

        <datalist id='el-ls-markers'>
          <option value='-0.025'></option>
          <option value='0.000'></option>
          <option value='0.025'></option>
          <option value='0.050'></option>
          <option value='0.075'></option>
          <option value='0.100'></option>
          <option value='0.125'></option>
          <option value='0.150'></option>
          <option value='0.175'></option>
          <option value='0.200'></option>
        </datalist>
      </div>

      <div class='sn-value'>
        <label for='el-tw-input' class='code'>text-wrap:</label>
        <select id='el-tw-input' name='text-wrap'>
          <option value='wrap' selected>wrap (Standard)</option>
          <option value='pretty'>pretty</option>
          <option value='balance'>balance</option>
        </select>
        <span>
          <output id='el-tw-output' class='code'>wrap</output>
        </span>
      </div>

      <div class='sn-value'>
        <label for='el-mis-input' class='code'>max-inline-size:</label>
        <input
          type='range'
          name='size'
          id='el-mis-input'
          min='30'
          max='75'
          step='5'
          value='65'
          list='el-mis-markers'
        />
        <span>
          <output id='el-mis-output' class='code'>65ch</output>
        </span>

        <datalist id='el-mis-markers'>
          <option value='30'></option>
          <option value='35'></option>
          <option value='40'></option>
          <option value='45'></option>
          <option value='50'></option>
          <option value='55'></option>
          <option value='60'></option>
          <option value='65'></option>
          <option value='70'></option>
          <option value='75'></option>
        </datalist>
      </div>
    </div>
  </Fragment>

  <Fragment>
    <div
      class='demo-container'
      style='--fs: 1rem; --lh: 1.4; --ls: 0.05em; --mis: 35ch'
    >
      <div class='headline'>
        Der finale Kilometer: Finjas Kampf um den Polizeidienst
      </div>

      <p class='bodytext'>
        Die Lungen brannten wie Feuer und jeder Schritt auf der Aschebahn fühlte
        sich an wie Blei, doch Finja hielt den Blick starr auf die unbarmherzig
        ablaufende Uhr gerichtet. Es war der alles entscheidende Cooper-Test für
        die Aufnahme in den Polizeidienst, bei dem sie nach Wochen des harten
        Trainings nur noch wenige Meter von ihrem großen Traum trennten. Während
        andere Bewerber bereits entkräftet aufgeben mussten, mobilisierte sie
        die allerletzten Reserven, ignorierte den stechenden Schmerz in der
        Seite und biss sich bis zum erlösenden Signalhorn durch.
      </p>
    </div>
  </Fragment>
</Snippet>

<style>
  @scope (.demo-container) {
    :scope {
      font-size: var(--fs);
      line-height: var(--lh);
      letter-spacing: var(--ls);

      .headline {
        font-family: var(--ff-headings);
        font-size: 1.875em;
        font-weight: var(--fw-bold);
        margin-block-end: 0.2em;
        text-wrap: wrap;
        transition: all 120ms linear;
      }

      .bodytext {
        max-inline-size: var(--mis);
        transition: all 120ms linear;
      }
    }
  }
</style>

<script is:inline>
  ;(function () {
    const snippetScope = document.currentScript?.closest('figure') ?? document
    const snDemoContainer = snippetScope.querySelector('.demo-container')
    const snHeadline = snippetScope.querySelector('.headline')
    const snFontSizeInput = snippetScope.querySelector('#el-fs-input')
    const snFontSizeOutput = snippetScope.querySelector('#el-fs-output')
    const snLineHeightInput = snippetScope.querySelector('#el-lh-input')
    const snLineHeightOutput = snippetScope.querySelector('#el-lh-output')
    const snLetterSpacingInput = snippetScope.querySelector('#el-ls-input')
    const snLetterSpacingOutput = snippetScope.querySelector('#el-ls-output')
    const snMaxInlineSizeInput = snippetScope.querySelector('#el-mis-input')
    const snMaxInlineSizeOutput = snippetScope.querySelector('#el-mis-output')
    const snTextWrapInput = snippetScope.querySelector('#el-tw-input')
    const snTextWrapOutput = snippetScope.querySelector('#el-tw-output')

    if (
      !snDemoContainer ||
      !snHeadline ||
      !snFontSizeInput ||
      !snFontSizeOutput ||
      !snLineHeightInput ||
      !snLineHeightOutput ||
      !snLetterSpacingInput ||
      !snLetterSpacingOutput ||
      !snMaxInlineSizeInput ||
      !snMaxInlineSizeOutput ||
      !snTextWrapInput ||
      !snTextWrapOutput
    ) {
      return
    }

    // Set initial values
    const snFontSizeValue = parseFloat(snFontSizeInput.value).toFixed(1)
    snFontSizeOutput.textContent = `${snFontSizeValue}rem`
    const snLineHeightValue = parseFloat(snLineHeightInput.value).toFixed(1)
    snLineHeightOutput.textContent = snLineHeightValue
    const snLetterSpacingValue = parseFloat(snLetterSpacingInput.value).toFixed(
      3
    )
    snLetterSpacingOutput.textContent = `${snLetterSpacingValue}em`
    const snMaxInlineSizeValue = parseFloat(snMaxInlineSizeInput.value).toFixed(
      0
    )
    snMaxInlineSizeOutput.textContent = `${snMaxInlineSizeValue}ch`
    const snTextWrapValue = snTextWrapInput.value
    snTextWrapOutput.textContent = snTextWrapValue

    // Sync the demo with control defaults on first render.
    snDemoContainer.style.setProperty('--fs', `${snFontSizeValue}rem`)
    snDemoContainer.style.setProperty('--lh', snLineHeightValue)
    snDemoContainer.style.setProperty('--ls', `${snLetterSpacingValue}em`)
    snDemoContainer.style.setProperty('--mis', `${snMaxInlineSizeValue}ch`)
    snHeadline.style.setProperty('text-wrap', snTextWrapValue)

    // Add Event Listeners
    snFontSizeInput.addEventListener('input', (event) => {
      const value = parseFloat(event.target.value).toFixed(1)
      snFontSizeOutput.textContent = `${value}rem`
      snDemoContainer.style.setProperty('--fs', `${value}rem`)
    })

    snLineHeightInput.addEventListener('input', (event) => {
      const value = parseFloat(event.target.value).toFixed(1)
      snLineHeightOutput.textContent = value
      snDemoContainer.style.setProperty('--lh', value)
    })

    snLetterSpacingInput.addEventListener('input', (event) => {
      const value = parseFloat(event.target.value).toFixed(3)
      snLetterSpacingOutput.textContent = `${value}em`
      snDemoContainer.style.setProperty('--ls', `${value}em`)
    })

    snMaxInlineSizeInput.addEventListener('input', (event) => {
      const value = parseFloat(event.target.value).toFixed(0)
      snMaxInlineSizeOutput.textContent = `${value}ch`
      snDemoContainer.style.setProperty('--mis', `${value}ch`)
    })

    snTextWrapInput.addEventListener('input', (event) => {
      const value = event.target.value
      snTextWrapOutput.textContent = value
      snHeadline.style.setProperty('text-wrap', value)
    })
  })()
</script>
